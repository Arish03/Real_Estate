# Frontend Environment Configuration

# Backend API URL
VITE_API_BASE_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000

# Application Settings
VITE_APP_NAME=Real Estate Management
VITE_APP_VERSION=1.0.0

# Maps Configuration (Leaflet)
VITE_MAP_TILE_PROVIDER=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_DEFAULT_LAT=40.7128
VITE_MAP_DEFAULT_LNG=-74.0060
VITE_MAP_DEFAULT_ZOOM=10

# Optional: Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Optional: Google Maps API Key (if using Google Maps instead of Leaflet)
VITE_GOOGLE_MAPS_API_KEY=
